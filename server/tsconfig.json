{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "rootDir": "../",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"],
    "noEmit": false,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "baseUrl": "../",
    "paths": {
      "*": ["../*"]
    }
  },
  "include": ["src/**/*", "../lib/**/*"],
  "exclude": ["node_modules", "dist", "../client", "../node_modules"]
}

